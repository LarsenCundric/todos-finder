{
  "name": "todos-finder",
  "version": "1.0.0",
  "description": "Scan any codebase for TODO/FIXME/HACK/XXX/NOTE comments and display them beautifully",
  "type": "module",
  "keywords": [
    "cli",
    "todo",
    "fixme",
    "hack",
    "comments",
    "codebase",
    "scanner",
    "developer-tools",
    "terminal",
    "git-blame",
    "code-quality"
  ],
  "author": "Larsen Cundric",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/larsencundric/todos-finder.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/"
  ],
  "bin": {
    "todos": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "13.1.0",
    "ignore": "7.0.5",
    "ora": "8.2.0",
    "prompts": "2.4.2",
    "string-width": "8.2.0"
  }
}
